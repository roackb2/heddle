{
  "name": "heddle",
  "version": "0.0.1",
  "description": "A minimal TypeScript runtime for tool-using agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx examples/repo-investigator.ts",
    "chat": "tsx examples/conversation.tsx",
    "repo-investigator:dev": "OPENAI_API_KEY=\"$PERSONAL_OPENAI_API_KEY\" tsx examples/repo-investigator.ts",
    "chat:dev": "OPENAI_API_KEY=\"$PERSONAL_OPENAI_API_KEY\" tsx examples/conversation.tsx",
    "test": "vitest run"
  },
  "keywords": [
    "agent",
    "llm",
    "tools",
    "runtime",
    "trace"
  ],
  "license": "MIT",
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^6.8.0",
    "openai": "^4.86.2",
    "pino": "^10.3.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
